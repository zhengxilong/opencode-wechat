{
  "name": "opencode-wechat",
  "version": "0.1.0",
  "description": "A WeChat bridge for OpenCode that lets you interact with OpenCode through WeChat.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/zhengxilong/opencode-wechat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhengxilong/opencode-wechat.git"
  },
  "bugs": {
    "url": "https://github.com/zhengxilong/opencode-wechat/issues"
  },
  "packageManager": "bun@1.3.10",
  "bin": {
    "opencode-wechat": "./dist/opencode-wechat"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "README.zh-CN.md",
    "wechat-channel.example.json",
    "LICENSE",
    "NOTICE.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts start",
    "login": "bun run src/index.ts login",
    "logout": "bun run src/index.ts logout",
    "status": "bun run src/index.ts status",
    "doctor": "bun run scripts/doctor.ts",
    "smoke": "bun run scripts/smoke.ts",
    "test": "bun run smoke",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "keywords": [
    "opencode",
    "wechat",
    "ai-coding",
    "bridge",
    "developer-tools"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.0"
  }
}
